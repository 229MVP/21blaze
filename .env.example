# Public client keys only — never put secrets here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# Feature flags — defaults are OFF in code; enable explicitly per environment.
EXPO_PUBLIC_ENABLE_LIVE_DUEL=false
EXPO_PUBLIC_ENABLE_QUICK_MATCH=false
EXPO_PUBLIC_ENABLE_RANKED_BETA=false
EXPO_PUBLIC_ENABLE_MONETIZATION_BETA=false
EXPO_PUBLIC_ENABLE_REWARDED_ADS=false
EXPO_PUBLIC_ENABLE_REWARDED_CURRENCY=false
EXPO_PUBLIC_ENABLE_INTERSTITIAL_ADS=false
EXPO_PUBLIC_ENABLE_STORE_PURCHASES=false
EXPO_PUBLIC_ENABLE_PROGRESSION_BETA=false
EXPO_PUBLIC_ENABLE_DAILY_REWARDS=false
EXPO_PUBLIC_ENABLE_DAILY_MISSIONS=false
EXPO_PUBLIC_ENABLE_PURCHASE_DIAGNOSTICS=false

# RevenueCat public SDK keys (not secret API keys)
# Test Store keys use the test_ prefix and can be shared across platforms.
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# AdMob — defaults to Google test IDs when empty (OK for development only)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID_ID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS_ID=

# Server-only (Supabase secrets — DO NOT put in Expo client):
# REVENUECAT_WEBHOOK_AUTHORIZATION=
# SUPABASE_SERVICE_ROLE_KEY=
