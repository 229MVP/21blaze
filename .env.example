# Public client keys only — never put secrets here.
# Do not commit real .env files with values.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# Internal Beta 0.9.0 — Solo + Test Store purchases.
# Multiplayer / progression stay OFF until deploy + two-device QA pass.
EXPO_PUBLIC_ENABLE_LIVE_DUEL=false
EXPO_PUBLIC_ENABLE_QUICK_MATCH=false
EXPO_PUBLIC_ENABLE_RANKED_BETA=false
EXPO_PUBLIC_ENABLE_MONETIZATION_BETA=true
EXPO_PUBLIC_ENABLE_REWARDED_ADS=false
EXPO_PUBLIC_ENABLE_REWARDED_CURRENCY=false
EXPO_PUBLIC_ENABLE_INTERSTITIAL_ADS=true
EXPO_PUBLIC_ENABLE_STORE_PURCHASES=true
EXPO_PUBLIC_ENABLE_PROGRESSION_BETA=false
EXPO_PUBLIC_ENABLE_DAILY_REWARDS=false
EXPO_PUBLIC_ENABLE_DAILY_MISSIONS=false
EXPO_PUBLIC_ENABLE_PURCHASE_DIAGNOSTICS=true

# RevenueCat public SDK keys (safe for client).
# Internal Beta / preview: use RevenueCat Test Store key (test_…).
# Production: use platform-specific public SDK keys (not Test Store).
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# AdMob — leave empty to use Google TEST unit IDs (required for Internal Beta).
# Production store builds must supply real production IDs via EAS secrets.
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID_ID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS_ID=

# Server-only (Supabase Edge Function secrets — NEVER put in Expo client / EAS EXPO_PUBLIC_*):
# REVENUECAT_WEBHOOK_AUTHORIZATION=
# SUPABASE_SERVICE_ROLE_KEY=
